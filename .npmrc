# NPM Configuration
# Ensures consistent behavior across all environments

# Use strict semver
save-prefix=^

# Disable audit on install (can be run separately)
ignore-scripts=false

# Use the npm registry
registry=https://registry.npmjs.org/

# Ensure workspaces work correctly
workspaces-update=false

# Always install devDependencies — build step needs drizzle-kit and other dev tools
# even when NODE_ENV=production (Render sets this globally)
production=false
