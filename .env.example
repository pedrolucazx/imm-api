# App Configuration
NODE_ENV=development
PORT=3001
API_HOST=localhost:3001
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/inside_my_mind_dev

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Provider selection
# Use comma-separated list for automatic fallback (e.g. AI_PROVIDER=gemini,openai)
STORAGE_PROVIDER=supabase            # supabase | s3 | r2
AI_PROVIDER=gemini                   # gemini | openai | anthropic
TRANSCRIPTION_PROVIDER=gemini        # gemini | whisper

# Gemini AI (required if AI_PROVIDER or TRANSCRIPTION_PROVIDER includes "gemini")
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-from-aistudio
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-flash-latest:generateContent

# Supabase Storage (required if STORAGE_PROVIDER=supabase)
# Get your credentials at: https://supabase.com/dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_STORAGE_BUCKET=avatars
SUPABASE_AUDIO_BUCKET=audio-entries

# Optional: Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_TIMEWINDOW=60000

# Resend Email Service (https://resend.com)
RESEND_API_KEY=re_your_resend_api_key
APP_URL=http://localhost:3000
