{
  "name": "imm-api",
  "version": "1.0.0",
  "description": "Backend API for Inside My Mind — habit tracking and AI journaling SaaS.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch --tsconfig tsconfig.src.json src/index.ts",
    "build": "swc src -d dist --strip-leading-paths --copy-files && tsc-alias -p tsconfig.src.json",
    "typecheck": "tsc --noEmit -p tsconfig.src.json",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.{ts,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,json,md}\"",
    "prepare": "node -e \"if (process.env.NODE_ENV !== 'production' && !process.env.CI) require('child_process').exec('husky install')\"",
    "commit": "cz commit",
    "test": "jest --config jest.config.cjs",
    "test:unit": "jest --config jest.config.cjs --selectProjects unit",
    "test:integration": "jest --config jest.config.cjs --selectProjects integration",
    "test:e2e": "jest --config jest.config.cjs --selectProjects e2e",
    "test:watch": "jest --config jest.config.cjs --watch",
    "test:coverage": "jest --config jest.config.cjs --coverage",
    "db:generate": "node -r tsx/cjs node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node -r tsx/cjs node_modules/drizzle-kit/bin.cjs migrate",
    "db:migrate:local": "DRIZZLE_ENV_FILE=.env.local node -r tsx/cjs node_modules/drizzle-kit/bin.cjs migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "DRIZZLE_ENV_FILE=.env.local node -r tsx/cjs node_modules/drizzle-kit/bin.cjs studio",
    "db:wipe": "tsx scripts/db-wipe.ts",
    "db:seed:local": "DRIZZLE_ENV_FILE=.env.local tsx scripts/db-seed-local.ts",
    "db:start": "docker compose up -d --wait && npm run db:migrate:local && npm run db:seed:local"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@supabase/supabase-js": "^2.99.0",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.1.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.0.0",
    "@commitlint/config-conventional": "^18.0.0",
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.18",
    "@testcontainers/postgresql": "^11.12.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.0",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "commitizen": "^4.3.0",
    "cz-conventional-changelog": "^3.3.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "husky": "^9.0.0",
    "is-ci": "^4.1.0",
    "jest": "^30.2.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "supertest": "^7.2.2",
    "testcontainers": "^11.12.0",
    "ts-jest": "^29.4.6",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.7.0",
    "typescript": "^5.4.5"
  }
}
